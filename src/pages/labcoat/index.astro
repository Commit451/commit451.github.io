---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="LabCoat for GitLab — A Native GitLab Client for Android & iOS"
  description="LabCoat is a native, open-source GitLab client for Android and iOS. Browse projects, issues, merge requests, pipelines, and more — all from your phone. Built with Kotlin Multiplatform by Commit 451."
  robots="index, follow"
  author="Commit 451 LLC"
  keywords="GitLab, Android, iOS, Kotlin, open source, GitLab client, mobile app, merge requests, pipelines, issues, LabCoat"
  canonical="https://labcoat.commit451.com/"
  ogType="website"
  ogTitle="LabCoat for GitLab — Native Mobile GitLab Client"
  ogDescription="Browse your GitLab projects, issues, merge requests, and pipelines from your phone. Open source, built with Kotlin Multiplatform."
  ogUrl="https://labcoat.commit451.com/"
  ogImage="https://commit451.com/images/labcoat_icon.png"
  ogSiteName="LabCoat for GitLab"
  twitterCard="summary"
  twitterSite="@Commit451"
  twitterTitle="LabCoat for GitLab — Native Mobile GitLab Client"
  twitterDescription="Browse your GitLab projects, issues, merge requests, and pipelines from your phone. Open source."
  twitterImage="https://commit451.com/images/labcoat_icon.png"
  favicon="/images/labcoat_icon.png"
  faviconType="image/png"
>
  <Fragment slot="head">
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "LabCoat for GitLab",
      "operatingSystem": "Android, iOS",
      "applicationCategory": "DeveloperApplication",
      "description": "A native, open-source GitLab client for Android and iOS. Browse projects, issues, merge requests, pipelines, and more.",
      "url": "https://labcoat.commit451.com",
      "image": "https://commit451.com/images/labcoat_icon.png",
      "author": {
        "@type": "Organization",
        "name": "Commit 451",
        "url": "https://commit451.com"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "installUrl": "https://play.google.com/store/apps/details?id=com.commit451.gitlab",
      "softwareVersion": "3.0",
      "isAccessibleForFree": true
    })} />
  </Fragment>

  <!-- Background -->
  <div class="fixed inset-0 -z-10">
    <img src="/images/bg.png" alt="" class="h-full w-full object-cover opacity-[0.07]" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-dark-950/40 via-dark-950/90 to-dark-950"></div>
  </div>

  <Navbar variant="labcoat" accentColor="accent" />

  <main>
    <!-- Hero -->
    <section class="min-h-screen flex items-center justify-center px-6 pt-20">
      <div class="max-w-3xl text-center reveal">
        <div class="flex justify-center mb-8">
          <div class="relative">
            <div class="absolute -inset-2 rounded-3xl bg-gradient-to-br from-brand-accent to-brand-accent opacity-50 blur-xl"></div>
            <img src="/images/labcoat_icon.png" alt="LabCoat for GitLab" width="140" height="140" class="relative rounded-3xl border-2 border-dark-700 shadow-2xl">
          </div>
        </div>
        <h1 class="font-arcane text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white">
          LabCoat
        </h1>
        <p class="mt-4 text-xl sm:text-2xl text-gray-400 font-light italic">Your GitLab, in your pocket.</p>
        <p class="mt-6 text-base sm:text-lg text-gray-300 leading-relaxed max-w-2xl mx-auto">
          A native, open-source GitLab client for Android and iOS. Browse projects, review merge requests,
          track issues, monitor pipelines — all from a fast, beautiful mobile app built with Kotlin Multiplatform.
        </p>

        <!-- Download buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://play.google.com/store/apps/details?id=com.commit451.gitlab" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center gap-3 rounded-lg bg-brand-accent px-8 py-3.5 text-sm font-semibold text-dark-950 hover:bg-brand-accent/90 transition-all hover:scale-105 shadow-lg shadow-brand-accent/20">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302-2.302 2.302-2.698-2.302 2.698-2.302zM5.864 3.458L16.8 9.79l-2.301 2.302-8.635-8.634z"/></svg>
            Google Play
          </a>
          <a href="https://gitlab.com/Commit451/LabCoat" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center gap-3 rounded-lg border border-dark-700 px-8 py-3.5 text-sm font-medium text-gray-300 hover:border-brand-accent hover:text-brand-accent transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 01-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 014.82 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0118.6 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.51L23 13.45a.84.84 0 01-.35.94z"/></svg>
            View Source
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-14 flex flex-wrap justify-center gap-8 sm:gap-14">
          <div>
            <p class="text-3xl font-fira font-bold text-brand-accent">50K+</p>
            <p class="mt-1 text-sm text-gray-500">Installs</p>
          </div>
          <div>
            <p class="text-3xl font-fira font-bold text-brand-accent">⭐ #1</p>
            <p class="mt-1 text-sm text-gray-500">Most Starred Kotlin Project on GitLab</p>
          </div>
          <div>
            <p class="text-3xl font-fira font-bold text-brand-accent">Free</p>
            <p class="mt-1 text-sm text-gray-500">& Open Source</p>
          </div>
        </div>

        <a href="#features" class="mt-16 inline-flex animate-bounce" aria-label="Scroll to Features section">
          <svg class="w-6 h-6 mx-auto text-gray-500 hover:text-brand-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </section>

    <!-- Screenshot Section -->
    <section class="py-24 px-6">
      <div class="mx-auto max-w-lg reveal">
        <div class="relative mx-auto w-[280px] rounded-[2.5rem] border-[3px] border-dark-700 bg-dark-900 p-3 shadow-2xl shadow-brand-accent/10">
          <img src="/images/labcoat_screenshot.png" alt="LabCoat app screenshot showing a GitLab project view" class="rounded-[2rem] w-full">
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-24 sm:py-32 px-6">
      <div class="mx-auto max-w-6xl">
        <div class="text-center reveal">
          <p class="text-sm font-fira font-bold text-brand-accent uppercase tracking-widest">Features</p>
          <h2 class="mt-4 text-3xl sm:text-4xl font-bold tracking-tight text-white">Everything you need from GitLab, on the go</h2>
        </div>
        <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Projects</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Browse projects, view READMEs with full markdown rendering, explore file trees, and star your favorites.</p>
          </article>

          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Issues</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Create, browse, and manage issues. Filter by assignee, label, or milestone. Comment and update on the go.</p>
          </article>

          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Merge Requests</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Review merge requests, view diffs, check approvals, and stay on top of your code review queue.</p>
          </article>

          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Pipelines</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Monitor CI/CD pipeline status, view job logs, and catch failures before they become problems.</p>
          </article>

          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Push Notifications</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Get notified about activity on your projects. Tap a notification and jump straight to the relevant screen.</p>
          </article>

          <article class="reveal rounded-2xl border border-dark-700/60 bg-dark-900/70 backdrop-blur-sm p-8 hover:border-brand-accent/40 transition-all duration-300 glow group">
            <div class="w-12 h-12 rounded-xl bg-brand-accent/10 flex items-center justify-center mb-6 group-hover:bg-brand-accent/20 transition-colors">
              <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </div>
            <h3 class="font-fira font-bold text-white text-lg">Self-Hosted Support</h3>
            <p class="mt-3 text-sm text-gray-400 leading-relaxed">Works with GitLab.com and self-hosted GitLab instances. Your server, your data, your rules.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Open Source callout -->
    <section class="py-24 px-6">
      <div class="mx-auto max-w-3xl reveal">
        <div class="rounded-2xl border border-brand-accent/40 bg-gradient-to-br from-dark-900/90 to-dark-800/50 backdrop-blur-sm p-10 text-center glow">
          <p class="text-sm font-fira font-bold text-brand-accent uppercase tracking-widest">Open Source</p>
          <h2 class="mt-4 text-2xl sm:text-3xl font-bold text-white">Built in the open, for the community</h2>
          <p class="mt-4 text-gray-400 leading-relaxed max-w-xl mx-auto">
            LabCoat is and always will be free and open source. Built with Kotlin Multiplatform,
            contributions are welcome. Check out the source, file issues, or submit a merge request.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="https://gitlab.com/Commit451/LabCoat" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-accent px-6 py-3 text-sm font-semibold text-dark-950 hover:bg-brand-accent/90 transition-all hover:scale-105 shadow-lg shadow-brand-accent/20">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 01-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 014.82 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0118.6 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.51L23 13.45a.84.84 0 01-.35.94z"/></svg>
              View on GitLab
            </a>
            <a href="https://gitlab.com/Commit451/LabCoat/-/issues" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center justify-center gap-2 rounded-lg border border-dark-700 px-6 py-3 text-sm font-medium text-gray-300 hover:border-brand-accent hover:text-brand-accent transition-all">
              Report an Issue
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6">
      <div class="mx-auto max-w-2xl text-center reveal">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Ready to try LabCoat?</h2>
        <p class="mt-4 text-lg text-gray-400">Free on Google Play. iOS coming soon.</p>
        <div class="mt-8">
          <a href="https://play.google.com/store/apps/details?id=com.commit451.gitlab" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center justify-center gap-3 rounded-lg bg-brand-accent px-10 py-4 text-base font-semibold text-dark-950 hover:bg-brand-accent/90 transition-all hover:scale-105 shadow-lg shadow-brand-accent/20">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302-2.302 2.302-2.698-2.302 2.698-2.302zM5.864 3.458L16.8 9.79l-2.301 2.302-8.635-8.634z"/></svg>
            Download on Google Play
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer accentColor="accent" useAbsoluteLinks={true} />
</BaseLayout>
